# Local development secrets for `wrangler dev`.
# Copy this file to `.dev.vars` (already gitignored) and fill in real values.
# `.dev.vars` is read automatically by `wrangler dev` — it is NOT used in
# production deploys, where secrets must be set via `wrangler secret put`.

# Required — must be >= 32 characters.
JWT_SECRET=replace-with-a-long-random-dev-only-string-min-32-chars

# Optional — when absent, OTP/verification emails are logged to the
# `wrangler dev` console instead of actually being sent.
BREVO_API_KEY=

# Optional — only needed to test the Super Admin bootstrap flow locally.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_SECRET_KEY=

# Required only if you've uncommented the ADMIN_HUB Durable Object binding
# in wrangler.toml (Workers Paid plan).
INTERNAL_BROADCAST_SECRET=
